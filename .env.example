# =============================================================================
# DragonPulse environment configuration
# Copy this file to ".env" and fill in your values. Never commit ".env".
# All settings are also overridable via real environment variables.
# Prefix for all DragonPulse settings is DRAGONPULSE_ (see config/settings.py).
# =============================================================================

# -----------------------------------------------------------------------------
# SAM.gov API keys
# -----------------------------------------------------------------------------
# You start with a BASIC personal key (10 requests/day). Paste it here.
DRAGONPULSE_SAM_API_KEY_BASIC=PASTE_YOUR_BASIC_KEY_HERE

# Once your entity registration completes, paste your higher-limit key here.
# Leave blank until you have it.
DRAGONPULSE_SAM_API_KEY_SYSTEM=

# Which key tier to use: "basic" or "system".
# Keep "basic" during early development; switch to "system" later.
DRAGONPULSE_API_KEY_TIER=basic

# -----------------------------------------------------------------------------
# Search defaults
# -----------------------------------------------------------------------------
# Comma-separated NAICS codes to pre-select in the sidebar (your primary codes).
# Example: DRAGONPULSE_DEFAULT_NAICS=541512,541330,541611
DRAGONPULSE_DEFAULT_NAICS=

# -----------------------------------------------------------------------------
# Caching (heavily favored to stay under the 10 req/day basic limit)
# -----------------------------------------------------------------------------
# TTL in seconds for cached API responses. 21600 = 6h, 86400 = 24h.
DRAGONPULSE_CACHE_TTL_SECONDS=43200
# Set to "true" to bypass the cache and always hit the network (use sparingly!).
DRAGONPULSE_CACHE_DISABLED=false
# Hard daily request budget guardrail. The client refuses live calls past this.
DRAGONPULSE_DAILY_REQUEST_BUDGET=9

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# DEBUG, INFO, WARNING, ERROR
DRAGONPULSE_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Optional LLM (opt-in). Without this, DragonPulse uses deterministic templates.
# Works with OpenAI OR any OpenAI-compatible local server (Ollama, LM Studio, vLLM).
# -----------------------------------------------------------------------------
# Master switch. "false" = no external LLM calls ever (fully local templates).
DRAGONPULSE_LLM_ENABLED=false

# --- Recommended: fully-local LLM via Ollama (private, no cloud) -------------
# Primary recommended model: Llama 3.3 70B (Q3_K_M quant) — strong reasoning,
# runs locally. It needs ~34 GB RAM/VRAM; if that's too heavy, qwen2.5:14b or
# llama3.2:3b are good lighter fallbacks.
# 1) Install Ollama (https://ollama.com), then:
#      ollama pull llama3.3:70b-instruct-q3_K_M
# 2) Uncomment the three lines below and set DRAGONPULSE_LLM_ENABLED=true.
# DRAGONPULSE_LLM_BASE_URL=http://localhost:11434/v1
# DRAGONPULSE_LLM_MODEL=llama3.3:70b-instruct-q3_K_M
# DRAGONPULSE_LLM_API_KEY=ollama        # any placeholder; local servers ignore it

# --- Alternative: cloud provider (OpenAI) -----------------------------------
# Leave DRAGONPULSE_LLM_BASE_URL blank and set a real key + model.
DRAGONPULSE_LLM_BASE_URL=
DRAGONPULSE_LLM_API_KEY=
DRAGONPULSE_LLM_MODEL=llama3.3:70b-instruct-q3_K_M
DRAGONPULSE_LLM_TEMPERATURE=0.3

# -----------------------------------------------------------------------------
# RAG knowledge base (local, on-disk vector store for past proposals)
# -----------------------------------------------------------------------------
# Embedding backend: auto | hashing | ollama | sentence_transformers
#   hashing  = zero-dependency, offline, lexical (default-safe)
#   ollama   = local semantic embeddings (needs DRAGONPULSE_LLM_BASE_URL set)
#   auto     = ollama if a local server is configured, else hashing
DRAGONPULSE_RAG_EMBEDDING_BACKEND=auto
# Model for ollama/sentence_transformers (e.g. nomic-embed-text). Run first:
#   ollama pull nomic-embed-text
DRAGONPULSE_RAG_EMBEDDING_MODEL=nomic-embed-text
DRAGONPULSE_RAG_CHUNK_CHARS=1200
DRAGONPULSE_RAG_CHUNK_OVERLAP=200
DRAGONPULSE_RAG_TOP_K=5
# Max upload size per file for the Knowledge Base (MB). Default 1000 = 1 GB.
# Keep in sync with maxUploadSize in .streamlit/config.toml; restart after changes.
DRAGONPULSE_KB_MAX_UPLOAD_MB=1000
# Auto-OCR scanned/image-only PDFs on upload (needs pymupdf + pytesseract + the
# Tesseract engine, e.g. `brew install tesseract`). Skipped gracefully if missing.
DRAGONPULSE_KB_OCR_ENABLED=true
DRAGONPULSE_KB_OCR_DPI=200
